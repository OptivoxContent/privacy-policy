{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build.mjs",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/((?!privacy-policy|favicon.ico|vyreel-emblem.png).*)", "destination": "/privacy-policy", "permanent": false }
  ]
}
